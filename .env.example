# Google Gemini API Key — required for simulations (backend)
# Get yours at: https://aistudio.google.com/app/apikey
# Copy this file to .env.local and paste your real key there (never commit .env.local).
GEMINI_API_KEY=

# Plausible Analytics domain — frontend, build-time only (prefix VITE_ is required by Vite).
# Set to your Plausible site domain (e.g. syntheticusers.com) to enable tracking in production.
# Leave empty in .env.local to keep analytics as a no-op during development.
VITE_PLAUSIBLE_DOMAIN=

# Public app URL — used for og:image and social meta tags (no trailing slash).
# In Vercel, set to your production domain: https://yourdomain.com
VITE_APP_URL=
